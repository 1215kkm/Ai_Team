# 쉘 스크립트는 Windows 에서도 LF 로 체크아웃 — CRLF 면 bash 가 syntax error
*.sh text eol=lf
*.bash text eol=lf

# PowerShell 은 CRLF 가 자연스러움
*.ps1 text eol=crlf

# 텍스트 기본
*.md   text
*.json text
*.yml  text
*.yaml text
*.txt  text
*.css  text
*.html text

# 바이너리 명시 (자동 감지 실패 방지)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
